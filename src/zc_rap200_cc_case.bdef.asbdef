projection;

define behavior for ZC_RAP200_CC_CASE alias CrisisCase
{
  use create;
  use update;
  use delete;

  use association _RecoveryOptions { create; }

  use action generateAndRecommendOptions;
}

define behavior for ZC_RAP200_CC_OPT alias RecoveryOption
{
  use update;
  use delete;

  use association _CrisisCase;
}